# ─── Rutas ───────────────────────────────────────────────────────────────────
MUNDIAL_DIRECTORIO_BASE=./Mundial_Partidos

# ─── qBittorrent Web API ─────────────────────────────────────────────────────
QBIT_HOST=127.0.0.1
QBIT_PORT=8080
QBIT_USER=admin
QBIT_PASS=adminadmin

# ─── Búsqueda y fallback ─────────────────────────────────────────────────────
MUNDIAL_RENOMBRAR_ARCHIVOS=1
QBIT_LIMPIAR_AUXILIARES=1
YTDLP_HORAS_ESPERA_POST_PARTIDO=24
YTDLP_DURACION_MAXIMA=10800
YTDLP_ALTURA_MINIMA=720

# ─── Compatibilidad web del index.html ───────────────────────────────────────
# Genera MP4 con video copiado y audio AAC cuando el origen trae audio AC3/DTS.
WEB_COMPAT_POSTPROCESO=1
WEB_COMPAT_AUDIO_BITRATE=192k
WEB_COMPAT_AUDIO_CHANNELS=2
WEB_COMPAT_MIN_FREE_GB=1.0
WEB_COMPAT_CONSERVAR_ORIGINAL=1
WEB_COMPAT_RETIRAR_TORRENT_ORIGINAL=1

# ─── Groq API opcional ───────────────────────────────────────────────────────
GROQ_API_KEY=
GROQ_HABILITADO=0
GROQ_MODEL=openai/gpt-oss-20b
